# Invoicestack Environment Variables
# Copy to .env for local dev

# Firebase (auto from firebase config in most cases)
# VITE_FIREBASE_API_KEY=...

# EmailJS (recommended for real email sending)
VITE_EMAILJS_SERVICE_ID=
VITE_EMAILJS_TEMPLATE_ID=
VITE_EMAILJS_PUBLIC_KEY=

# Optional legacy AI (Gemini)
GEMINI_API_KEY=

# Public URL for links / auth
APP_URL=http://localhost:3001

# Hermes / SolidAI Integration (future)
# HERMES_ENDPOINT=http://100.75.107.78:8000 or your local agent
# SOLIDAI_API_KEY=
